<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xycy.chestimaging.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.xycy.chestimaging.model.User">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="name" property="name"/>
        <result column="department" property="department"/>
        <result column="role" property="role" typeHandler="org.apache.ibatis.type.EnumTypeHandler"/>
        <result column="password" property="password"/>
        <result column="status" property="status" typeHandler="org.apache.ibatis.type.EnumTypeHandler"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="last_login" property="lastLogin"/>
    </resultMap>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM user WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="BaseResultMap">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM user
    </select>

    <insert id="insert" parameterType="com.xycy.chestimaging.model.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, name, department, role, password, status, created_time, updated_time, last_login) 
                VALUES (#{username}, #{name}, #{department}, #{role}, #{password}, #{status}, #{createdTime}, #{updatedTime}, #{lastLogin})
    </insert>

    <update id="update" parameterType="com.xycy.chestimaging.model.User">
        UPDATE user SET username = #{username}, name = #{name}, department = #{department}, 
                role = #{role}, status = #{status}, updated_time = #{updatedTime}, password = #{password}, 
                last_login = #{lastLogin} WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM user WHERE id = #{id}
    </delete>

    <select id="count" resultType="java.lang.Long">
        SELECT COUNT(*) FROM user
    </select>

    <select id="findByCondition" resultMap="BaseResultMap">
        SELECT * FROM user 
        <where>
        <if test="username != null">
          username LIKE CONCAT('%', #{username}, '%')
          <if test="department != null or role != null or status != null">AND</if>
        </if>
        <if test="department != null">
          department LIKE CONCAT('%', #{department}, '%')
          <if test="role != null or status != null">AND</if>
        </if>
        <if test="role != null">
          role = #{role}
          <if test="status != null">AND</if>
        </if>
        <if test="status != null">
          status = #{status}
        </if>
        </where>
        LIMIT #{offset}, #{pageSize}
    </select>

    <select id="countByCondition" resultType="java.lang.Long">
        SELECT COUNT(*) FROM user 
        <where>
        <if test="username != null">
          username LIKE CONCAT('%', #{username}, '%')
          <if test="department != null or role != null or status != null">AND</if>
        </if>
        <if test="department != null">
          department LIKE CONCAT('%', #{department}, '%')
          <if test="role != null or status != null">AND</if>
        </if>
        <if test="role != null">
          role = #{role}
          <if test="status != null">AND</if>
        </if>
        <if test="status != null">
          status = #{status}
        </if>
        </where>
    </select>

</mapper>